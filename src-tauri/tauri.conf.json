{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalKeys",
  "version": "0.7.0",
  "identifier": "com.localkeys.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1456",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalKeys",
        "width": 1040,
        "height": 720,
        "minWidth": 680,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
